{
  "name": "@d4dent/platform",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "frontend/*",
    "backend/apps/*",
    "backend/libs/*"
  ],
  "scripts": {
    "start": "nx run-many --target=serve --all",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "typecheck": "nx run-many --target=typecheck --all",
    "affected:apps": "nx affected:apps",
    "affected:build": "nx affected:build",
    "affected:test": "nx affected:test",
    "affected:lint": "nx affected:lint",
    "graph": "nx graph",
    "format": "prettier --write \"**/*.{ts,js,json,md,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,scss}\"",
    "db:migrate": "npm run --prefix backend/libs/data-access migrate",
    "db:seed": "npm run --prefix backend/libs/data-access seed",
    "dev": "nodemon --watch frontend/app --watch backend/apps --watch backend/libs -e ts --exec \"npm run build && npm run start\"",
    "dev:local": "docker-compose -f docker-compose.local.yml up",
    "dev:payment": "cd backend/apps/payment-service && npm run dev"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "@google-cloud/storage": "^7.0.0",
    "@opentelemetry/api": "1.7.0",
    "@opentelemetry/sdk-node": "^0.47.0",
    "@sendgrid/mail": "^7.7.0",
    "@sinclair/typebox": "^0.31.0",
    "@upstash/redis": "^1.20.0",
    "ajv": "^8.12.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "bson": "^6.0.0",
    "bullmq": "^5.13.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "i18next": "^23.7.0",
    "i18next-http-middleware": "^3.5.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "nanoid": "^5.0.0",
    "node-telegram-bot-api": "^0.63.0",
    "nodemailer": "^6.9.7",
    "openai": "^4.29.0",
    "pino": "^9.0.0",
    "pino-http": "^9.0.0",
    "prom-client": "^15.0.0",
    "reflect-metadata": "^0.2.1",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^4.19.0",
    "uuid": "^9.0.0",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash": "^4.14.200",
    "@types/morgan": "^1.9.5",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.0",
    "@types/validator": "^13.11.0",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.2",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "@opentelemetry/api": "1.7.0",
    "gcp-metadata": "5.3.0",
    "gaxios": "5.1.3"
  }
}
