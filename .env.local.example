.env.local.example
# Local Development Environment

# MongoDB
MONGODB_URI=mongodb://admin:admin123@localhost:27017/d4dent?authSource=admin
MONGODB_USER=admin
MONGODB_PASS=admin123

# Server
NODE_ENV=development
PORT=3000
PAYMENT_SERVICE_URL=http://localhost:3003

# CORS - Allow all local development ports
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3006,http://localhost:3007

# Optional: Configure for production testing
# PhonePe Sandbox
PHONEPE_MERCHANT_ID=PGTESTPAYUAT
PHONEPE_SALT_KEY=your_phonepe_salt_key
PHONEPE_SALT_INDEX=1
PAYMENT_CALLBACK_BASE_URL=http://localhost:3003
PAYOUT_WINDOW_DAYS=7

# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890
# NSCD_API_KEY=your_nsdc_api_key

# Email (Optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
